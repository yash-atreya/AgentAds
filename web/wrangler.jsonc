{
  "name": "agentads-web",
  "account_id": "5c092c371cd84b2b7fa81441956c6466",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets"
  },

  // Custom domain configuration
  "routes": [
    {
      "pattern": "agentads.xyz/*",
      "zone_name": "agentads.xyz"
    },
    {
      "pattern": "www.agentads.xyz/*",
      "zone_name": "agentads.xyz"
    }
  ],

  // Environment variables (if needed)
  "vars": {
    "NEXT_PUBLIC_API_URL": "https://agent-ads.yashatreya-ya.workers.dev"
  }
}